# OCBC Ahead — environment
# The OFFLINE demo (npm run dev) needs NONE of this and works with no network/key.
# These power the optional "Live (LLM)" Ask path (npm run dev:full). Pick ONE:

# FREE, NO KEY — local model via Ollama. Install https://ollama.com, then `ollama pull llama3.2`.
OLLAMA_MODEL=llama3.2
OLLAMA_HOST=http://localhost:11434

# FREE, needs a key — Google Gemini. Get a key at https://aistudio.google.com/apikey
# Tip: gemini-3.1-flash-lite has higher free-tier RPM than gemini-2.5-flash (thinking is auto-disabled for both).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# PAID — Anthropic Claude (separate from a Claude Pro subscription)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

PORT=8787
